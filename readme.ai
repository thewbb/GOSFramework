### 5.5 `core/Unit.js` — 单位系统

```js
export class Unit {
  // 只读属性
  get id() {}       // '{unitId}_{team}_{序号}'，如 'Mecha1_player_0'
  get team() {}     // 'player' | 'enemy'
  get tile() {}     // [tx, ty]
  get stats() {}    // UnitStats（含实时 hp）
  get hasMoved() {}
  get hasAttacked() {}
  get isAlive() {}

  /**
   * 沿路径逐格移动动画
   * @param {[number,number]}   tile
   * @param {[number,number][]} path
   * @returns {Promise<void>}
   */
  async moveTo(tile, path) {}

  /** hp 归零时自动调用 die() */
  takeDamage(amount) {}

  /** 不超过 maxHp */
  heal(amount) {}

  /** 播放死亡动画后从 layers.units 移除 @returns {Promise<void>} */
  async die() {}

  /** 由 Battle 在回合结束时调用，外部禁止调用 */
  resetTurn() {}
}

// ─────────────────────────────────────

export class UnitManager {
  /**
   * @param {Renderer} renderer
   * @param {Map}      map
   * @param {EventBus} events
   */
  constructor(renderer, map, events) {}

  /** @param {DeployEntry[]} deployList @returns {Promise<void>} */
  async deploy(deployList) {}

  /**
   * @param {object}           unitData  MechaXxx.js 导出对象
   * @param {'player'|'enemy'} team
   * @param {[number,number]}  tile
   * @returns {Unit}
   */
  add(unitData, team, tile) {}

  /** 仅数据层移除，不触发死亡动画 */
  remove(unit) {}

  /** @returns {Unit|null} */
  get(id) {}

  /** 仅返回存活单位 @returns {Unit[]} */
  getByTeam(team) {}

  /** @returns {Unit|null} */
  getAt(tile) {}

  /** @returns {Unit[]} */
  all() {}
}

// ─────────────────────────────────────

export class AIBase {
  /**
   * @param {UnitManager} units
   * @param {Map}         map
   * @param {Battle}      battle
   */
  constructor(units, map, battle) {}

  /**
   * 串行执行所有敌方单位本回合行动
   * @returns {Promise<void>}
   */
  async executeTurn() {}
}

/**
 * @typedef {object} UnitStats
 * @property {number} hp
 * @property {number} maxHp
 * @property {number} atk
 * @property {number} def
 * @property {number} move   每回合可移动格数
 * @property {number} range  攻击射程（格）
 */

/**
 * @typedef {object} DeployEntry
 * @property {string}           unitId
 * @property {'player'|'enemy'} team
 * @property {[number,number]}  tile
 */
```

