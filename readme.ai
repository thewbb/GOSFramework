## 三、坐标系约定（全局）

```js
// ✅ 格子坐标 —— 数组，整数
const tile = [tx, ty]                    // 例：[3, 5]

// ✅ 像素坐标 —— 对象
const pixel = { px, py }                 // 例：{ px: 192, py: 320 }

// ✅ 转换由 Map 实例提供，任何模块不得自行计算
map.tileToPixel([tx, ty])   → { px, py }
map.pixelToTile({ px, py }) → [tx, ty]

// ❌ 禁止使用 {x, y}、{col, row}、[px, py] 等其他格式
```

---

## 四、命名规范

| 类别 | 规范 | 示例 |
|------|------|------|
| 类名 | PascalCase | `Battle`, `UnitManager` |
| 实例/变量 | camelCase | `battle`, `unitManager` |
| 常量/枚举 | UPPER_SNAKE | `Events.UNIT_DIED` |
| 格子坐标变量 | tx, ty | `const [tx, ty] = unit.tile` |
| 像素坐标变量 | px, py | `const { px, py } = map.tileToPixel(...)` |
| 阵营字符串 | 小写字面量 | `'player'`, `'enemy'` |
| 事件名 | 使用常量，禁止字符串字面量 | `Events.TURN_START` ✅ |
| 文件名（类） | PascalCase | `Battle.js` |
| 文件名（关卡） | camelCase | `level1.js` |

---

## 五、模块接口全览

### 5.1 `main.js` — 入口

```js
/**
 * 执行顺序：
 *   1. 创建 PixiJS Application 并挂载到 document.body
 *   2. 创建 Renderer，传入 app
 *   3. 创建 EventBus
 *   4. 导入并启动第一个关卡
 */
import { Application } from 'pixi.js'
import { Renderer }    from './core/Renderer.js'
import { EventBus }    from './core/Event.js'
import level1          from './levels/level1.js'

const app      = new Application()
const renderer = new Renderer(app)
const events   = new EventBus()
level1.start(renderer, events)
```

---

### 5.2 `core/Renderer.js` — 渲染器

```js
export class Renderer {
  /** @param {Application} app */
  constructor(app) {}

  /**
   * 图层引用（按渲染顺序从下到上，只读）
   * @type {{
   *   background: Container,
   *   terrain:    Container,
   *   decoration: Container,
   *   highlight:  Container,
   *   units:      Container,
   *   effects:    Container,
   *   ui:         Container,
   *   dialog:     Container,
   * }}
   */
  get layers() {}

  /** @returns {{ width: number, height: number }} */
  get size() {}
}
```

---

### 5.3 `core/Event.js` — 事件系统

```js
export class EventBus {
  on(event, handler) {}
  once(event, handler) {}
  off(event, handler) {}
  emit(event, payload) {}
}

export const Events = {
  TURN_START:    'turnStart',    // { team, turn }
  TURN_END:      'turnEnd',      // { team }
  UNIT_MOVED:    'unitMoved',    // { unit, from: [tx,ty], to: [tx,ty] }
  UNIT_ATTACKED: 'unitAttacked', // { attacker, target, damage }
  UNIT_HP_BELOW: 'unitHpBelow', // { unit, threshold }
  UNIT_DIED:     'unitDied',     // { unit }
  TEAM_WIPED:    'teamWiped',    // { team }
  TILE_ENTERED:  'tileEntered',  // { unit, tile }
  DIALOG_DONE:   'dialogDone',   // { key }
  LEVEL_WIN:     'levelWin',     // {}
  LEVEL_LOSE:    'levelLose',    // {}
}
```

---

### 5.4 `core/Map.js` — 瓦片地图

```js
export class Map {
  /** @param {Renderer} renderer  @param {MapData} mapData */
  constructor(renderer, mapData) {}

  /** 切割图集，渲染三层瓦片 @returns {Promise<void>} */
  async render() {}

  /** @param {[number,number]} tile @returns {{ px, py }} */
  tileToPixel([tx, ty]) {}

  /** @param {{ px, py }} pixel @returns {[number,number]} */
  pixelToTile({ px, py }) {}

  /** @param {[number,number]} tile @returns {boolean} */
  isPassable([tx, ty]) {}

  /** @param {[number,number]} tile @returns {TileProps} */
  getTileProps([tx, ty]) {}

  /**
   * 高亮格子（可多次调用叠加，不自动清除）
   * @param {[number,number][]} tiles
   * @param {number} color  0xRRGGBB
   * @param {number} alpha  默认 0.4
   */
  highlight(tiles, color, alpha = 0.4) {}

  clearHighlight() {}

  /** 四邻格，过滤越界 @returns {[number,number][]} */
  getNeighbors([tx, ty]) {}

  /**
   * A* 寻路，不穿越单位和不可通行格
   * @returns {[number,number][]}  含起点和终点，无路返回 []
   */
  findPath(from, to, maxSteps = Infinity) {}

  /**
   * BFS 获取可达格集合
   * @returns {[number,number][]}
   */
  getReachable(origin, steps) {}

  get cols() {}
  get rows() {}
}

/**
 * @typedef {object} MapData
 * @property {number}   cols
 * @property {number}   rows
 * @property {number}   tileSize          当前 16px，后期替换为 64px
 * @property {string}   tilesetPath
 * @property {number}   tilesetCols       图集每行瓦片数
 * @property {{ background: number[][], terrain: number[][], decoration: number[][] }} layers
 * @property {Object.<number, TileProps>} tileProps
 * @property {DeployEntry[]} deploy
 * @property {Object.<string, DialogLine[]>} dialogs
 * @property {string}   bgm
 */

/**
 * @typedef {object} TileProps
 * @property {boolean} passable
 * @property {string}  type  'ground'|'mountain'|'water'|'crater'|'deco'
 */
```

