### 5.6 `core/Battle.js` — 战斗控制器

```js
export class Battle {
  /**
   * @param {Renderer}      renderer
   * @param {Map}           map
   * @param {UnitManager}   units
   * @param {EffectManager} effects
   * @param {EventBus}      events
   */
  constructor(renderer, map, units, effects, events) {}

  // ── 流程控制 ──────────────────────────

  /** 部署单位，发出第一个 TURN_START @returns {Promise<void>} */
  async start(levelData) {}

  /**
   * 结束当前回合，切换阵营
   * 流程：resetTurn → TURN_END → TURN_START → 若enemy则executeTurn
   * @returns {Promise<void>}
   */
  async nextTurn() {}

  get currentTeam() {} // 'player' | 'enemy'
  get turn() {}        // number，从 1 开始

  // ── 玩家行动接口（由 UI 调用）────────────

  /**
   * 移动单位（含合法性校验）
   * 成功：unit.hasMoved=true，发出 UNIT_MOVED
   * @returns {Promise<boolean>}
   */
  async moveUnit(unit, targetTile) {}

  /**
   * 发起攻击（含合法性校验、伤害计算、特效）
   * 成功：unit.hasAttacked=true，发出 UNIT_ATTACKED
   * 目标死亡：发出 UNIT_DIED，全灭时发出 TEAM_WIPED
   * @returns {Promise<boolean>}
   */
  async attackUnit(attacker, target) {}

  /** 标记单位本回合行动结束（hasMoved 和 hasAttacked 均置 true） */
  endUnitTurn(unit) {}

  // ── 工具函数 ──────────────────────────

  /**
   * 预计算伤害（不扣血，供 UI 预览和 AI 决策使用）
   * 公式：max(1, atk - def)
   * @returns {number}
   */
  calcDamage(attacker, target) {}
}
```

---

### 5.7 `core/Dialog.js` — 叙事系统

```js
export class DialogManager {
  /**
   * @param {Renderer} renderer
   * @param {EventBus} events
   */
  constructor(renderer, events) {}

  /**
   * 顺序播放对话，每条等待点击/按键推进
   * 全部结束后发出 Events.DIALOG_DONE { key }
   * @param {DialogLine[]} lines
   * @param {string}       key
   * @returns {Promise<void>}
   */
  async show(lines, key) {}

  /** 立即关闭，不发事件 */
  hide() {}
}

// ─────────────────────────────────────

export class SceneManager {
  /** @param {Renderer} renderer */
  constructor(renderer) {}

  /** 跳转关卡，传入关卡模块的 default export */
  async goto(levelModule) {}

  /** 显示标题画面，玩家确认后 resolve @returns {Promise<void>} */
  async showTitle() {}

  /** @param {'win'|'lose'} result @returns {Promise<void>} */
  async showResult(result) {}
}

/**
 * @typedef {object} DialogLine
 * @property {string} speaker
 * @property {string} text
 * @property {string} [face]  头像路径（可选）
 */
```

