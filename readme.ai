### 5.11 `levels/level1.js` — 关卡文件结构

```js
/**
 * 关卡文件：数据 + 逻辑一体，default export 一个对象。
 *
 * 必须导出：
 *   export default { start(renderer, events) }
 *
 * start() 内部执行顺序：
 *   1. 实例化所有核心模块
 *   2. await map.render()
 *   3. 注册胜负条件监听
 *   4. await dialog.show(opening)
 *   5. await battle.start(mapData)
 */

import { Map }           from '../core/Map.js'
import { Battle }        from '../core/Battle.js'
import { UnitManager }   from '../core/Unit.js'
import { EffectManager } from '../core/EffectManager.js'
import { DialogManager } from '../core/Dialog.js'
import { Events }        from '../core/Event.js'
import Mecha1            from '../units/Mecha1.js'

// ── 地图数据 ────────────────────────────────────────────

const mapData = {
  cols: 16,
  rows: 10,
  tileSize: 16,
  tilesetPath: 'assets/tilesets/tileset_arranged.png',
  tilesetCols: 16,

  layers: {
    background: [
      // 10 行 × 16 列，值为瓦片 ID（id = row*16 + col）
    ],
    terrain: [
      // 0 = 无地形
    ],
    decoration: [
      // 0 = 无点缀
    ],
  },

  tileProps: {
    0:  { passable: true,  type: 'ground' },
    // ...根据实际图集补充
  },

  deploy: [
    { unitId: 'Mecha1', team: 'player', tile: [2, 5] },
    { unitId: 'Mecha1', team: 'enemy',  tile: [13, 5] },
  ],

  dialogs: {
    opening: [
      { speaker: '指挥官', text: '目标已确认，开始战斗。' },
    ],
    victory: [
      { speaker: '指挥官', text: '干得好，撤退。' },
    ],
    defeat: [
      { speaker: '指挥官', text: '任务失败，全员撤离。' },
    ],
  },

  bgm: 'assets/audio/level1.mp3',
}

// ── 关卡逻辑 ────────────────────────────────────────────

export default {
  /**
   * @param {Renderer} renderer
   * @param {EventBus} events
   */
  async start(renderer, events) {
    const map     = new Map(renderer, mapData)
    const units   = new UnitManager(renderer, map, events)
    const effects = new EffectManager(renderer)
    const dialog  = new DialogManager(renderer, events)
    const battle  = new Battle(renderer, map, units, effects, events)

    // 渲染地图
    await map.render()

    // 胜负条件
    events.on(Events.TEAM_WIPED, ({ team }) => {
      if (team === 'enemy')  events.emit(Events.LEVEL_WIN,  {})
      if (team === 'player') events.emit(Events.LEVEL_LOSE, {})
    })

    // 开场对话
    await dialog.show(mapData.dialogs.opening, 'opening')

    // 启动战斗
    await battle.start(mapData)
  },
}
```

---

## 六、资源规范

### 6.1 瓦片图集

| 文件 | 规格 | 说明 |
|------|------|------|
| `tileset_arranged.png` | 256×256px，每格 16px，16×16 布局 | 当前使用 |
| `tileset_compressed.png` | 同上，排列不同 | 备用 |

```
瓦片 ID 计算：id = row * tilesetCols + col
例：第3行第2列 → id = 3 * 16 + 2 = 50
```

> ⚠️ tileSize 和 tilesetCols 后期换高清图时只需修改 mapData，代码无需改动。

### 6.2 单位精灵图

```
assets/units/
  mecha1.png     单帧或帧动画图集（待定规格）
```

### 6.3 技能时序脚本示例

```js
// assets/effects/skills/laser_shot.js
export const sequence = [
  { t: 0,   action: 'sfx',        id: 'laser_charge' },
  { t: 0,   action: 'anim',       target: 'attacker', clip: 'shoot' },
  { t: 200, action: 'laser',      target: 'target' },
  { t: 400, action: 'explosion',  target: 'target',   type: 'small' },
  { t: 400, action: 'damage',     target: 'target' },
  { t: 600, action: 'end' },
]
```

