### 5.8 `core/EffectManager.js` — 特效系统

```js
export class EffectManager {
  /** @param {Renderer} renderer */
  constructor(renderer) {}

  /** 激光束（直线） @returns {Promise<void>} */
  async laser(from, to, options = {}) {}
  // options: { color?: number, width?: number, duration?: number }

  /** 抛射物（弧线飞行） @returns {Promise<void>} */
  async projectile(from, to, options = {}) {}
  // options: { type?: 'missile'|'bullet', speed?: number }

  /** 爆炸（帧动画+粒子） @returns {Promise<void>} */
  async explosion(at, options = {}) {}
  // options: { size?: 'small'|'medium'|'large' }

  /** 护盾光圈 @returns {Promise<void>} */
  async shield(unit, options = {}) {}
  // options: { color?: number, duration?: number }

  /** 推进器尾焰 @returns {Promise<void>} */
  async propulsion(unit, options = {}) {}
  // options: { duration?: number }

  /** 全屏特效 @returns {Promise<void>} */
  async screen(type, options = {}) {}
  // type: 'flash'|'shake'|'darken'
  // options: { intensity?: number, duration?: number }

  /** 通用粒子 @returns {Promise<void>} */
  async particle(at, options = {}) {}
  // options: { count?, color?, spread?, duration? }

  /**
   * 播放完整技能时序脚本
   * @param {SequenceStep[]} sequence
   * @param {{ attacker: Unit, target: Unit }} context
   * @returns {Promise<void>}
   */
  async playSequence(sequence, context) {}
}

/**
 * @typedef {object} SequenceStep
 * @property {number} t       触发时间（ms，相对技能开始）
 * @property {'sfx'|'anim'|'projectile'|'explosion'|'laser'|'screen'|'damage'|'end'} action
 * @property {string} [id]
 * @property {'attacker'|'target'} [target]
 * @property {string} [clip]
 * @property {string} [type]
 */
```

